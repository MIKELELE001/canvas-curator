# Hedera Testnet Credentials
# Get these from portal.hedera.com (free testnet account)

HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=your_ed25519_private_key_here

# Artist wallet that receives the 0.1 HBAR on purchase
# Can be a second testnet account you control
ARTIST_WALLET_ID=0.0.XXXXXX

# HCS Topic ID — create one via Hedera portal or SDK
# Example creation: new TopicCreateTransaction().execute(client)
HCS_TOPIC_ID=0.0.XXXXXX
